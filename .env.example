PORT=3333
JWT_SECRET=troque-este-segredo-local-por-um-valor-forte
SESSION_COOKIE=barberpro_session
DEFAULT_TENANT_ID=tenant_local
DEFAULT_TENANT_NAME=Barbearia Local
DEFAULT_TENANT_SLUG=barbearia-local
CORS_ORIGIN=http://localhost:5173
DATA_FILE=./data/barberpro.json
WHATSAPP_NUMBER=5511999999999
# Em produto real, mantenha recursos de demonstracao desligados.
DEMO_AUTO_RENEW=false
# Opcional: defina quando o QR publico precisar apontar para um host fixo.
# Se vazio, a interface usa o origin local atual, como http://localhost:5173.
VITE_PUBLIC_APP_URL=

# Use "mysql" para persistir no XAMPP, ou "json" para arquivo local.
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=barberpro
DB_CONNECTION_LIMIT=5
DB_CONNECT_TIMEOUT_MS=2000
# Em producao, use false. Em dev local, readonly ajuda quando MySQL estiver desligado.
DB_FALLBACK_TO_JSON=readonly
REPORT_CACHE_TTL_MS=60000
MAX_APPOINTMENT_DAYS_AHEAD=365
AUTO_BACKUP_ENABLED=false
BACKUP_DIR=./data/backups
BACKUP_KEEP=7
HEALTH_MIN_FREE_DISK_MB=512
HEALTH_MAX_HEAP_MB=1024
LOG_LEVEL=debug
DEMO_RESET_ENABLED=false
DEMO_RESET_KEY=
