{
  "name": "barberpro",
  "version": "1.0.0",
  "description": "Sistema completo de agenda, gestão comercial, fidelidade e automação para barbearias.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "node server/index.js",
    "client": "vite --host 0.0.0.0",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "npm run build"
  },
  "keywords": [
    "barbearia",
    "agenda",
    "gestao",
    "react",
    "express"
  ],
  "author": "BarberPro",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.22.3",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.5"
  }
}
