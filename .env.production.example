# Runtime
NODE_ENV=production
PORT=3333
LOG_LEVEL=info
DEFAULT_TENANT_ID=tenant_sua_barbearia
DEFAULT_TENANT_NAME=Sua Barbearia
DEFAULT_TENANT_SLUG=sua-barbearia
PRODUCTION_BOOTSTRAP_DONE=false

# Gere com:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=COLE_AQUI_UM_SEGREDO_BASE64URL_DE_64_BYTES_GERADO_COM_CRYPTO

# Cookie httpOnly usado pela API. Use um nome fixo e sem espacos.
SESSION_COOKIE=__Host-barberpro_session

# Primeiro usuario criado quando a base de producao estiver vazia.
# Apos o primeiro deploy e troca de senha, remova FIRST_ADMIN_PASSWORD e use PRODUCTION_BOOTSTRAP_DONE=true.
FIRST_ADMIN_EMAIL=admin@seudominio.com.br
FIRST_ADMIN_PASSWORD=COLE_AQUI_UMA_SENHA_FORTE_COM_12_OU_MAIS_CARACTERES
FIRST_ADMIN_NAME=Administrador
FIRST_ADMIN_PHONE=5511999999999

# Origem HTTPS exata do frontend em producao. Separe multiplas origens por virgula se necessario.
CORS_ORIGIN=https://app.seudominio.com.br
VITE_PUBLIC_APP_URL=https://app.seudominio.com.br

# Banco relacional obrigatorio em producao
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_USER=barberpro_app
DB_PASSWORD=COLE_AQUI_UMA_SENHA_FORTE_DO_MYSQL
MYSQL_ROOT_PASSWORD=COLE_AQUI_UMA_SENHA_ROOT_FORTE_DO_MYSQL
MYSQL_DATABASE=barberpro
MYSQL_USER=barberpro_app
MYSQL_PASSWORD=COLE_AQUI_A_MESMA_SENHA_DE_DB_PASSWORD
DB_NAME=barberpro
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=5000
DB_FALLBACK_TO_JSON=false

# JSON local fica apenas como seed/migracao. Em producao, nao use como fonte principal.
DATA_FILE=./data/barberpro.json

# Backups automaticos
AUTO_BACKUP_ENABLED=true
BACKUP_DIR=/app/backups
BACKUP_KEEP=7
BACKUP_INTERVAL_MS=21600000
BACKUP_TIMEOUT_MS=120000
MYSQLDUMP_BIN=mysqldump

# Health check
HEALTH_MIN_FREE_DISK_MB=1024
HEALTH_MAX_HEAP_MB=1024

# Relatorios
REPORT_CACHE_TTL_MS=60000

# Agendamento
MAX_APPOINTMENT_DAYS_AHEAD=365

# Recuperacao de senha por e-mail. Use credenciais reais do provedor SMTP.
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_FROM=no-reply@seudominio.com.br
SMTP_USER=no-reply@seudominio.com.br
SMTP_PASS=COLE_AQUI_A_SENHA_SMTP
PASSWORD_RESET_EMAIL_SUBJECT=Redefinicao de senha BarberPro

# WhatsApp: integre com provedor real antes de depender de disparos automaticos.
WHATSAPP_NUMBER=5511999999999
ALERT_PROVIDER=stub
ALERT_WEBHOOK_URL=

# Reset de demo deve ficar desligado em producao.
DEMO_AUTO_RENEW=false
DEMO_RESET_ENABLED=false
DEMO_RESET_KEY=
